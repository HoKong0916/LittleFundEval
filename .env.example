# ═══════════════════════════════════════════════════════════════════
# DeepSeek（云端 LLM，评估 + 查询）
# ═══════════════════════════════════════════════════════════════════
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-pro

# ═══════════════════════════════════════════════════════════════════
# 本地 LLM（llama.cpp + Qwen3.5 GGUF）
# ═══════════════════════════════════════════════════════════════════
LLAMA_MODEL_PATH=./models/Qwen3.5-9B-UD-Q4_K_XL.gguf
LLAMA_SERVER_PATH=./llamacpp/llama-server.exe
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=9856

# ── 推理参数 ──
LLAMA_N_GPU_LAYERS=-1
LLAMA_CTX_SIZE=32768
LLAMA_FLASH_ATTENTION=on
LLAMA_PARALLEL=1
LLAMA_THINKING=off

# ── 投机解码 (MTP) ──
LLAMA_SPEC_TYPE=draft-mtp
LLAMA_SPEC_DRAFT_N_MAX=2

# ── 云端降级：本地 LLM 不可用时自动切换 DeepSeek（1=允许，0=禁止）──
LLM_FALLBACK_TO_CLOUD=1

# ── llama-server 兼容 OpenAI 的 API 地址 ──
LLAMA_CPP_BASE_URL=http://localhost:9856/v1

# ═══════════════════════════════════════════════════════════════════
# Redis（会话记忆 + Trace 日志）
# ═══════════════════════════════════════════════════════════════════
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════
# 调试
# ═══════════════════════════════════════════════════════════════════
DEBUG_TRACE=1
